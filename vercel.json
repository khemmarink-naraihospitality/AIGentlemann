{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/hf/:path*", "destination": "/api/hf?path=:path*" },
    { "source": "/api/fal/:path*", "destination": "/api/fal?path=:path*" },
    { "source": "/api/pexels/:path*", "destination": "/api/pexels?path=:path*" }
  ]
}
